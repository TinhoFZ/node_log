<h1>Users</h1>

<h2>Sign up</h2>
<form action="/users/register" method="POST">

    <label for="email">
        Input email:<span style="color: red;">*</span>
    </label>
    <input name="email" type="email" placeholder="Dudu@yahoo.com" required>

    <br>

    <label for="password">
        Input password:<span style="color: red;">*</span>
    </label>
    <input name="password" type="password" placeholder="SenhaMuitoSegura#123" required>

    <br>

    <button type="submit">Sign up</button>
</form>

<h2>Sign in</h2>
<form action="/users/login" method="POST">

    <label for="email">
        Input email:<span style="color: red;">*</span>
    </label>
    <input name="email" type="email" placeholder="Dudu@yahoo.com" required>

    <br>

    <label for="password">
        Input password:<span style="color: red;">*</span>
    </label>
    <input name="password" type="password" placeholder="SenhaMuitoSegura#123" required>

    <br>

    <button type="submit">Sign in</button>
</form>