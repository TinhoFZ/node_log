<h1>Sign Up</h1>
<form action="/users" method="POST" class="form">
    <div class="form-control">

        <div class="form-container">
            <label for="email">
                Input email:<span style="color: red;">*</span>
            </label>
            <input type="email" name="email" placeholder="Dudu@yahoo.com" required>
        </div>    

        <div class="form-container">
            <label for="password">
                Input password:<span style="color: red;">*</span>
            </label>
            <input type="password" name="password" placeholder="SenhaMuitoSegura#123" required>
        </div>
    </div>
    <input type="submit" value="Cadastrar">
</form>